# Basic configuration without database.
# For the bundled PostgreSQL setup, see `docker-compose.with-db.yml.example`.
services:
  beshence_vault:
    build: .
    image: beshence_vault:latest
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      DATABASE_URL: ${DATABASE_URL:-}
      JWT_SECRET: ${JWT_SECRET}
      JWT_TTL_SECONDS: ${JWT_TTL_SECONDS:-3600}
    ports:
      - "${HOST_PORT:-27462}:27462"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:27462/api/ping || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
