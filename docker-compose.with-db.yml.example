# Configuration with internal database
services:
  beshence_vault:
    build: .
    image: beshence_vault:latest
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      DATABASE_URL: "postgres://vault:vault@postgres:5432/vault?sslmode=disable"
      JWT_SECRET: ${JWT_SECRET:-local_dev_secret_change_me}
      JWT_TTL_SECONDS: ${JWT_TTL_SECONDS:-3600}
    ports:
      - "${HOST_PORT:-27462}:27462"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:27462/api/ping || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
    depends_on:
      postgres:
        condition: service_healthy
  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: vault
      POSTGRES_USER: vault
      POSTGRES_PASSWORD: vault
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U vault -d vault"]
      interval: 10s
      timeout: 5s
      retries: 10

volumes:
  postgres_data:

